# ========================================
# Padel Club OS - Variables de Entorno
# ========================================
# Copia este archivo como .env y rellena los valores.
# Las variables con NEXT_PUBLIC_ son visibles en el navegador.

# --- Base de Datos (requerido) ---
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/padel_club_os"

# --- Autenticacion NextAuth (requerido) ---
# Generar con: openssl rand -base64 32
AUTH_SECRET="generar-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe - Pagos y Suscripciones (requerido si facturacion activa) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."

# --- Email con Resend (requerido si emails activos) ---
RESEND_API_KEY="re_..."
CONTACT_EMAIL="contacto@tudominio.com"

# --- Notificaciones Push VAPID (requerido si push activo) ---
# Generar par de claves con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contacto@tudominio.com"

# --- Cron Jobs (requerido si recordatorios activos) ---
# Token secreto para autorizar llamadas a /api/cron/*
CRON_SECRET="generar-token-aleatorio"

# --- SEO y URLs publicas ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Monitoring con Sentry (opcional, recomendado en produccion) ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Solo necesario en CI/produccion para subir source maps
SENTRY_AUTH_TOKEN=""
