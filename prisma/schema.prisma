// Path: prisma/schema.prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CENTRAL MODEL: THE CLUB ---
model Club {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  address          String?
  logoUrl          String?
  openingTime      String?   @default("09:00")
  closingTime      String?   @default("23:00")
  subscriptionTier String    @default("essential")
  stripeCustomerId String?   @unique

  // Configuracion del portal publico
  description       String?
  phone             String?
  email             String?
  primaryColor      String?  @default("#4f46e5")
  bannerUrl         String?
  instagramUrl      String?
  facebookUrl       String?
  maxAdvanceBooking Int?     @default(7)     // dias de antelacion para reservar
  cancellationHours Int?     @default(2)     // horas antes para cancelar
  enableOpenMatches Boolean  @default(true)
  enablePlayerBooking Boolean @default(true)
  bookingDuration   Int?     @default(90)    // duracion de reserva en minutos (60, 90, 120)

  // Stripe - Suscripcion SaaS
  stripeSubscriptionId    String?
  subscriptionStatus      String?   @default("trialing")
  trialEndsAt             DateTime?

  // Stripe Connect - Pagos de reservas (preparado para fase D)
  stripeConnectAccountId  String?
  stripeConnectOnboarded  Boolean  @default(false)

  // Modo de pago de reservas: "online" | "presential" | "both"
  bookingPaymentMode      String?  @default("presential")

  // Relationships
  admins        User[]
  courts        Court[]
  bookings      Booking[]
  competitions  Competition[]
  openMatches   OpenMatch[]
  news          News[]
  payments      Payment[]
  courtPricings CourtPricing[]
  playerStats   PlayerStats[]
  notifications Notification[]
  broadcasts    Broadcast[]
  recurringBookings RecurringBooking[]
  bookingPayments   BookingPayment[]
  chatMessages      ChatMessage[]
  playerRatings     PlayerRating[]
  bookingWaitlists  BookingWaitlist[]
}

// --- USER ROLES ---
enum UserRole {
  SUPER_ADMIN
  CLUB_ADMIN
  STAFF
  PLAYER
}

// --- USER AND AUTHENTICATION MODELS ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  phone         String?
  emailVerified DateTime?
  image         String?
  position      String?
  level         String?
  birthDate     DateTime?
  role          UserRole  @default(PLAYER)
  isActive      Boolean   @default(true)
  mustResetPassword Boolean @default(false)
  adminNotes    String?   @db.Text

  clubId        String?
  club          Club?     @relation(fields: [clubId], references: [id])
  
  accounts      Account[]
  sessions      Session[]
  
  teamsAsPlayer1 Team[]    @relation("Player1OfTeams")
  teamsAsPlayer2 Team[]    @relation("Player2OfTeams")
  bookings      Booking[]
  openMatches   OpenMatchPlayer[]
  payments      Payment[]
  playerStats   PlayerStats[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  cookieConsents    CookieConsent[]
  broadcastsSent    Broadcast[]     @relation("BroadcastsSent")
  recurringBookingsAssigned RecurringBooking[] @relation("RecurringBookingsAssigned")
  bookingPaymentsAsPlayer   BookingPayment[] @relation("BookingPaymentsAsPlayer")
  bookingPaymentsCollected  BookingPayment[] @relation("BookingPaymentsCollected")
  ratingsGiven     PlayerRating[] @relation("RatingsGiven")
  ratingsReceived  PlayerRating[] @relation("RatingsReceived")
  chatMessages     ChatMessage[]
  bookingWaitlists BookingWaitlist[]

  @@index([clubId])
  @@index([clubId, role])
}

// --- NextAuth Models ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique  // SHA-256 hash del token original
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// --- BOOKING AND COURTS MODULE ---
model Court {
  id       String    @id @default(cuid())
  name     String
  type     String    @default("Indoor")
  clubId   String
  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  bookings Booking[]
  openMatches OpenMatch[]
  pricings CourtPricing[]
  recurringBookings RecurringBooking[]
  bookingWaitlists  BookingWaitlist[]

  @@index([clubId])
}

model Booking {
  id         String   @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  totalPrice Float
  courtId    String
  court      Court    @relation(fields: [courtId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  guestName  String?
  clubId     String
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  status        String     @default("confirmed")
  paymentStatus String?    @default("pending") // "pending" | "paid" | "exempt"
  paymentMethod String?    // "online" | "presential" | "exempt"
  cancelledAt     DateTime?
  cancelReason    String?
  reminderSentAt  DateTime?
  numPlayers      Int?       @default(4) // 2, 3 o 4 jugadores
  createdAt       DateTime   @default(now())

  // Checkout Session tracking (idempotencia + expiracion)
  checkoutSessionId        String?
  checkoutSessionExpiresAt DateTime?
  checkoutLockUntil        DateTime?

  openMatch       OpenMatch?
  payment         Payment?
  bookingPayments BookingPayment[]

  recurringBookingId String?
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id], onDelete: SetNull)

  @@unique([courtId, startTime])
  @@index([clubId])
  @@index([clubId, startTime])
  @@index([userId])
  @@index([status, startTime])
  @@index([paymentMethod, paymentStatus, status])
}

// --- UNIFIED COMPETITION MODULE ---
enum CompetitionFormat {
  LEAGUE
  KNOCKOUT
  GROUP_AND_KNOCKOUT
}

// --- AÑADIR ESTE ENUM ---
enum CompetitionStatus {
  ACTIVE
  FINISHED
}

model Competition {
  id        String   @id @default(cuid())
  name      String
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  format    CompetitionFormat @default(LEAGUE)
  rounds    Int      @default(1)
  status    CompetitionStatus @default(ACTIVE) // <-- AÑADIR ESTA LÍNEA
  groupSize Int?
  teamsPerGroupToAdvance Int?
  teams     Team[]
  matches   Match[]

  @@index([clubId])
}

model Team {
  id          String @id @default(cuid())
  name        String
  player1Id   String
  player1     User   @relation("Player1OfTeams", fields: [player1Id], references: [id], onDelete: Cascade)
  player2Id   String
  player2     User   @relation("Player2OfTeams", fields: [player2Id], references: [id], onDelete: Cascade)
  competitionId String
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  group       String?
  points      Int @default(0)
  played      Int @default(0)
  won         Int @default(0)
  lost        Int @default(0)
  setsFor     Int @default(0)
  setsAgainst Int @default(0)
  gamesFor    Int @default(0)
  gamesAgainst Int @default(0)
  matchesAsTeam1 Match[] @relation("MatchesAsTeam1")
  matchesAsTeam2 Match[] @relation("MatchesAsTeam2")
  @@unique([competitionId, player1Id, player2Id])
}

model Match {
  id        String    @id @default(cuid())
  result    String?
  matchDate DateTime?
  roundNumber Int
  roundName   String?
  winnerId    String?
  team1Id   String?
  team1     Team?      @relation("MatchesAsTeam1", fields: [team1Id], references: [id], onDelete: NoAction)
  team2Id   String?
  team2     Team?      @relation("MatchesAsTeam2", fields: [team2Id], references: [id], onDelete: NoAction)
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
}

// --- MÓDULO DE PARTIDAS ABIERTAS (PLAY!) ---

enum OpenMatchStatus {
  OPEN
  FULL
  CONFIRMED
  CANCELLED
}

model OpenMatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  matchTime DateTime
  status    OpenMatchStatus @default(OPEN)
  levelMin  Float?
  levelMax  Float?
  
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id])
  
  players   OpenMatchPlayer[]
  chatMessages ChatMessage[]
  ratings      PlayerRating[]

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @unique

  @@index([clubId])
  @@index([clubId, status])
}

model OpenMatchPlayer {
  openMatchId String
  openMatch   OpenMatch @relation(fields: [openMatchId], references: [id], onDelete: Cascade)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@id([openMatchId, userId])
}

// --- NOTICIAS DEL CLUB ---
model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  published Boolean  @default(false)
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([clubId, published])
}

// --- PAGOS ---
model Payment {
  id              String   @id @default(cuid())
  amount          Float
  currency        String   @default("EUR")
  status          String   // "succeeded" | "pending" | "failed" | "refunded"
  type            String   // "booking" | "subscription"
  stripePaymentId String?  @unique

  bookingId       String?  @unique
  booking         Booking? @relation(fields: [bookingId], references: [id])

  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([clubId])
  @@index([userId])
}

// --- RANKING / ESTADISTICAS DE JUGADOR ---
model PlayerStats {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId        String
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  eloRating     Float    @default(1500)
  matchesPlayed Int      @default(0)
  matchesWon    Int      @default(0)
  setsWon       Int      @default(0)
  setsLost      Int      @default(0)
  gamesWon      Int      @default(0)
  gamesLost     Int      @default(0)
  winStreak     Int      @default(0)
  bestWinStreak Int      @default(0)
  averageRating Float?   // promedio estrellas recibidas (null = sin valoraciones)
  totalRatings  Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([clubId, eloRating])
}

// --- PRECIOS POR PISTA ---
model CourtPricing {
  id        String @id @default(cuid())
  courtId   String
  court     Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  dayOfWeek Int    // 0=Domingo, 6=Sabado
  startHour Int    // 0-23
  endHour   Int    // 0-23
  price     Float
  clubId    String
  club      Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([courtId, dayOfWeek, startHour])
  @@index([clubId])
}

// --- FORMULARIO DE CONTACTO (plataforma) ---
model ContactSubmission {
  id             String   @id @default(cuid())
  nombre         String
  email          String
  asunto         String
  mensaje        String   @db.Text
  leido          Boolean  @default(false)
  // --- Campos demo funnel ---
  tipo           String?  @default("general") // "general" | "demo"
  clubNombre     String?
  numeroPistas   Int?
  softwareActual String?
  urgencia       String?
  paginaOrigen   String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  createdAt      DateTime @default(now())

  @@index([tipo])
}

// --- BLOG DE LA PLATAFORMA ---
model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   @db.Text
  excerpt    String
  category   String
  imageUrl   String?
  published  Boolean  @default(false)
  authorName String
  readTime   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, createdAt])
}

// --- NOTIFICACIONES ---
model Notification {
  id        String   @id @default(cuid())
  type      String   // booking_confirmed, booking_cancelled, booking_reminder, open_match_created, open_match_full, open_match_joined, news_published
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?    // { bookingId?, openMatchId?, newsId?, url? }
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([clubId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([endpoint])
}

// --- REGISTRO DE CONSENTIMIENTO RGPD ---
model CookieConsent {
  id        String   @id @default(cuid())
  tipo      String   // "all" | "essential"
  ip        String?  // IP anonimizada (ultimo octeto → xxx)
  userAgent String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- RESERVAS RECURRENTES (CLASES FIJAS) ---
model RecurringBooking {
  id          String    @id @default(cuid())
  description String?   // "Clase Juan y Maria - Lunes 10:00"
  dayOfWeek   Int       // 0=Domingo ... 6=Sabado (mismo formato que CourtPricing)
  startHour   Int       // 0-23
  startMinute Int       @default(0) // 0 o 30
  endHour     Int       // 0-23
  endMinute   Int       @default(0)
  isActive    Boolean   @default(true)
  startsAt    DateTime  // Desde cuando genera reservas
  endsAt      DateTime  // Hasta cuando genera reservas

  courtId     String
  court       Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation("RecurringBookingsAssigned", fields: [userId], references: [id])
  guestName   String?
  clubId      String
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  bookings    Booking[] // Reservas generadas por esta recurrencia
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clubId])
  @@index([clubId, isActive])
}

// --- COMUNICACIONES MASIVAS ---
model Broadcast {
  id             String   @id @default(cuid())
  title          String
  message        String   @db.Text
  channels       String   // "push" | "email" | "push+email"
  segment        String   // "all" | "active" | "inactive" | "level:X"
  recipientCount Int
  status         String   @default("sending") // "sending" | "sent" | "failed"

  sentById       String
  sentBy         User     @relation("BroadcastsSent", fields: [sentById], references: [id])
  clubId         String
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([clubId])
}

// --- PAGOS POR JUGADOR (tracking recepcion) ---
model BookingPayment {
  id            String    @id @default(cuid())
  bookingId     String
  booking       Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?     @relation("BookingPaymentsAsPlayer", fields: [userId], references: [id], onDelete: SetNull)
  guestName     String?   // Para jugadores no registrados
  amount        Float     // totalPrice / numPlayers
  status        String    @default("pending") // "pending" | "paid"
  paidAt        DateTime?
  collectedById String?
  collectedBy   User?     @relation("BookingPaymentsCollected", fields: [collectedById], references: [id], onDelete: SetNull)
  clubId        String
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([bookingId])
  @@index([clubId, status])
}

// --- VALORACIONES POST-PARTIDO ---
model PlayerRating {
  id          String    @id @default(cuid())
  raterId     String
  rater       User      @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  ratedId     String
  rated       User      @relation("RatingsReceived", fields: [ratedId], references: [id], onDelete: Cascade)
  openMatchId String
  openMatch   OpenMatch @relation(fields: [openMatchId], references: [id], onDelete: Cascade)
  stars       Int       // 1-5
  comment     String?   @db.VarChar(280)
  clubId      String
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([raterId, ratedId, openMatchId])
  @@index([ratedId, clubId])
  @@index([openMatchId])
  @@index([clubId])
}

// --- CHAT DE PARTIDA ABIERTA ---
model ChatMessage {
  id          String    @id @default(cuid())
  content     String    @db.VarChar(500)
  openMatchId String
  openMatch   OpenMatch @relation(fields: [openMatchId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  clubId      String
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([openMatchId, createdAt])
  @@index([clubId])
}

// --- LISTA DE ESPERA DE RESERVAS ---
model BookingWaitlist {
  id        String    @id @default(cuid())
  courtId   String
  court     Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  startTime DateTime  // Inicio exacto del slot (misma timezone que Booking.startTime)
  endTime   DateTime  // Fin exacto del slot
  status    String    @default("active") // active | notified | fulfilled | expired
  notifiedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([courtId, startTime, userId])
  @@index([courtId, startTime, status])
  @@index([clubId, userId])
}